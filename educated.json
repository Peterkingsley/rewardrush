-- This script will completely reset and populate the Education page tables.

-- Drop existing tables to ensure a clean slate
DROP TABLE IF EXISTS user_material_progress, study_plan_days, study_plans, team_members, teams, education_experts, education_materials, education_skills CASCADE;

-- Create the table for the main skills/categories
CREATE TABLE education_skills (
    id VARCHAR(50) PRIMARY KEY,
    title VARCHAR(255) NOT NULL,
    icon VARCHAR(100),
    color VARCHAR(50),
    courses INT,
    hours INT,
    description TEXT
);

-- Create the table for the learning materials within each skill
CREATE TABLE education_materials (
    id INT PRIMARY KEY,
    skill_id VARCHAR(50) REFERENCES education_skills(id) ON DELETE CASCADE,
    title VARCHAR(255) NOT NULL,
    type VARCHAR(50),
    duration VARCHAR(50)
);

-- Create a table to track which materials a user has completed
CREATE TABLE user_material_progress (
    user_id INT REFERENCES users(id) ON DELETE CASCADE,
    material_id INT REFERENCES education_materials(id) ON DELETE CASCADE,
    completed_at TIMESTAMPTZ DEFAULT NOW(),
    PRIMARY KEY (user_id, material_id)
);

-- Create a table for the "Learn" page experts
CREATE TABLE education_experts (
    id INT PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    title VARCHAR(255),
    avatar VARCHAR(255),
    bio TEXT,
    socials JSONB, -- Store social links as a JSON object
    portfolio JSONB -- Store portfolio items as a JSON array
);

-- Create a table for user-created study plans
CREATE TABLE study_plans (
    id SERIAL PRIMARY KEY,
    user_id INT REFERENCES users(id) ON DELETE CASCADE NOT NULL,
    skill_id VARCHAR(50) REFERENCES education_skills(id) ON DELETE CASCADE NOT NULL,
    goal TEXT NOT NULL,
    reminder_time TIME,
    created_at TIMESTAMPTZ DEFAULT NOW(),
    is_active BOOLEAN DEFAULT TRUE
);

-- Create a table to store the selected days for a study plan
CREATE TABLE study_plan_days (
    study_plan_id INT REFERENCES study_plans(id) ON DELETE CASCADE,
    day_of_week INT NOT NULL, -- 0 for Sunday, 1 for Monday, etc.
    PRIMARY KEY (study_plan_id, day_of_week)
);

-- Create a table for study teams
CREATE TABLE teams (
    id SERIAL PRIMARY KEY,
    skill_id VARCHAR(50) REFERENCES education_skills(id) ON DELETE CASCADE NOT NULL,
    creator_id INT REFERENCES users(id) ON DELETE CASCADE NOT NULL,
    team_name VARCHAR(255),
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- Create a table for team members and their invitation status
CREATE TABLE team_members (
    team_id INT REFERENCES teams(id) ON DELETE CASCADE,
    user_id INT REFERENCES users(id) ON DELETE CASCADE,
    invited_email VARCHAR(255),
    status VARCHAR(50) DEFAULT 'Pending', -- Pending, Accepted, Declined
    invited_at TIMESTAMPTZ DEFAULT NOW(),
    accepted_at TIMESTAMPTZ,
    PRIMARY KEY (team_id, user_id)
);

